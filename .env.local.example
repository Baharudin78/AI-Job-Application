# =============================================================================
# AI Job Application Coach — Environment Variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
# Rule (CLAUDE.md): NEXT_PUBLIC_* is exposed to the browser and must be
# non-sensitive. Everything else is server-only and may be a secret.
# =============================================================================

# ----- App ------------------------------------------------------------------
# Public base URL of the app (used for auth redirects, email links, webhooks).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----- Supabase (Auth + Storage) --------------------------------------------
# Project URL and anon key from: Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# Service role key — SERVER ONLY. Bypasses Row Level Security. Never expose.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ----- Database (Prisma → Supabase Postgres) --------------------------------
# Pooled connection (PgBouncer, port 6543) for the app at runtime.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) used by Prisma for migrations / db push.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres"

# ----- Claude / Anthropic (AI) ----------------------------------------------
# API key from: https://console.anthropic.com/ . SERVER ONLY.
ANTHROPIC_API_KEY="sk-ant-..."
# Primary model id (kept here so it is configurable without a code change).
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ----- Paddle Billing (Payments — Merchant of Record) -----------------------
# "sandbox" while testing, "production" when live.
PADDLE_ENVIRONMENT="sandbox"
# Server-side API key (Paddle → Developer Tools → Authentication).
PADDLE_API_KEY="your-paddle-api-key"
# Client-side token for Paddle.js checkout overlay (safe to expose).
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="your-paddle-client-token"
# Webhook signing secret — validate every incoming webhook with this.
PADDLE_WEBHOOK_SECRET="your-paddle-webhook-secret"
# Price IDs for each plan / interval (from Paddle → Catalog → Prices).
PADDLE_PRICE_PRO_MONTHLY="pri_..."
PADDLE_PRICE_PRO_ANNUAL="pri_..."
PADDLE_PRICE_BOOSTER_MONTHLY="pri_..."
PADDLE_PRICE_BOOSTER_ANNUAL="pri_..."

# ----- Resend (Transactional Email) -----------------------------------------
# API key from: https://resend.com/api-keys . SERVER ONLY.
RESEND_API_KEY="re_..."
# Verified sender address (must be on a domain you verified in Resend).
RESEND_FROM_EMAIL="AI Job Coach <noreply@yourdomain.com>"

# ----- Analytics & Monitoring (optional for MVP) ----------------------------
# PostHog — product analytics (safe to expose the public key).
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
# Sentry — error monitoring.
NEXT_PUBLIC_SENTRY_DSN=""
